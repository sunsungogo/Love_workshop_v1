<script>
const touched = new Set();
const mainKeys = ['1','2','3','4','5a','6','7','8','9','10','11a','12','13'];
const SAVE_KEY = 'love_ws_v4';
let partnerStatus = 'yes';

function setPartner(val) {
  partnerStatus = val;
  document.getElementById('ptYes').classList.toggle('active', val==='yes');
  document.getElementById('ptNo').classList.toggle('active', val==='no');
  ['q6text','q7text'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = el.dataset[val];
  });
  saveAll();
}

function upd(el) {
  const k = el.dataset.q;
  document.getElementById('v'+k).textContent = el.value;
  touched.add(k);
  const done = mainKeys.filter(k=>touched.has(k)).length;
  document.getElementById('pFill').style.width = Math.round(done/mainKeys.length*100)+'%';
  document.getElementById('pLbl').textContent = done+' / 13';
  saveAll();
}

function saveAll() {
  const data = {};
  document.querySelectorAll('[data-q]').forEach(el => { data['sl_'+el.dataset.q] = el.value; });
  ['uName','uDate','t1','t2','t3','r1','r2','r3','memo'].forEach(id => {
    const el = document.getElementById(id);
    if (el) data[id] = el.value;
  });
  data['partnerStatus'] = partnerStatus;
  localStorage.setItem(SAVE_KEY, JSON.stringify(data));
  const st = document.getElementById('saveStatus');
  st.textContent = '✓ 保存済み';
  st.className = 'save-status saved';
  setTimeout(() => { st.textContent = '— 自動保存'; st.className = 'save-status'; }, 1500);
}

function loadAll() {
  const raw = localStorage.getItem(SAVE_KEY);
  if (!raw) return;
  try {
    const data = JSON.parse(raw);
    document.querySelectorAll('[data-q]').forEach(el => {
      const v = data['sl_'+el.dataset.q];
      if (v !== undefined) {
        el.value = v;
        const valEl = document.getElementById('v'+el.dataset.q);
        if (valEl) valEl.textContent = v;
        touched.add(el.dataset.q);
      }
    });
    ['uName','uDate','t1','t2','t3','r1','r2','r3','memo'].forEach(id => {
      const el = document.getElementById(id);
      if (el && data[id] !== undefined) el.value = data[id];
    });
    const done = mainKeys.filter(k=>touched.has(k)).length;
    document.getElementById('pFill').style.width = Math.round(done/mainKeys.length*100)+'%';
    document.getElementById('pLbl').textContent = done+' / 13';
    if (data['partnerStatus']) setPartner(data['partnerStatus']);
  } catch(e) { console.warn('load failed', e); }
}

function resetAll() {
  if (!confirm('入力内容をすべてリセットしますか？')) return;
  localStorage.removeItem(SAVE_KEY);
  location.reload();
}

document.addEventListener('DOMContentLoaded', () => {
  loadAll();
  ['uName','uDate','r1','r2','r3','memo'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', saveAll);
  });
  ['t1','t2','t3'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('change', saveAll);
  });
});

function getVal(k) {
  const el = document.querySelector('[data-q="'+k+'"]');
  return el ? parseInt(el.value) : 5;
}

function buildData() {
  const s = {};
  ['1','2','3','4','5a','5b','6','7','8','9','10','11a','11b','12','13'].forEach(k=>s[k]=getVal(k));
  const gap5 = s['5b']-s['5a'];
  const gap11 = s['11b']-s['11a'];
  const name = document.getElementById('uName').value || '参加者';
  const t1 = document.getElementById('t1').value || '未選択';
  const t2 = document.getElementById('t2').value || '未選択';
  const t3 = document.getElementById('t3').value || '未選択';
  const r1 = document.getElementById('r1').value || 'なし';
  const r2 = document.getElementById('r2').value || 'なし';
  const r3 = document.getElementById('r3').value || 'なし';
  const memo = document.getElementById('memo').value || 'なし';

  // 値を自然言語に変換するヘルパー（3段階）
  function interp(val, lo, hi) {
    if (val <= 3) return `${val}（${lo}寄り）`;
    if (val >= 8) return `${val}（${hi}寄り）`;
    return `${val}（中間）`;
  }

  const partnerNote = partnerStatus === 'no'
    ? `\n【重要】この参加者は現在恋人がいない状態で、自分の理想・傾向として回答しています。\n- typeName・catchcopy・descriptionは「現在の恋愛」ではなく「その人の恋愛傾向・理想」として表現してください\n- hypothesesの具体アクションは「恋人をつくる・気になる人にアプローチする・関係をスタートさせる」文脈で提案してください\n- 「恋人と〇〇する」ではなく「好きな人に〇〇してみる」「出会いの場で〇〇を意識する」などの表現を使ってください`
    : '';

  return `【恋愛WSワークシート診断依頼】${partnerNote}

参加者：${name}
恋人：${partnerStatus === 'yes' ? 'いる' : 'いない（理想・傾向で回答）'}

スライダー結果（各設問の意味は末尾の解釈ガイドを参照）：
1.着火スピード: ${interp(s['1'],'直感・一目惚れ','スローバーン・友達から')}
2.主導権: ${interp(s['2'],'自分がリードしたい・引っ張りたい','リードされたい・おまかせ')}（中間=一緒に決めたい・対等）
3.関係を進めるペース: ${interp(s['3'],'早く距離を縮めたい（積極的）','ゆっくり深めたい（慎重）')}
4.時間の境界: ${interp(s['4'],'時間をすべてシェア','一人時間を優先')}
5a.浮気の許容ライン: ${interp(s['5a'],'身体的接触まではセーフ（寛容）','2人で会うだけでアウト（厳格）')}
5b.自分の実際の行動: ${interp(s['5b'],'絶対しない','やってしまうことがある')}
　→ 5aと5bのズレ: ${gap5>0?'+'+gap5:gap5}（プラス＝自分の行動が自分のラインより緩い）
6.独占欲: ${interp(s['6'],'気にしない（信頼）','独占したい')}
7.第三者の介入: ${interp(s['7'],'歓迎','受け入れたくない')}
8.対立の作法: ${interp(s['8'],'ホット・感情型','クール・論理型')}
9.恋愛的指向: ${interp(s['9'],'ドキドキ重視','友情・信頼重視')}
10.関係性のエンジン: ${interp(s['10'],'成長・刺激志向','癒し・安心志向')}
11a.自己開示（自分から）: ${interp(s['11a'],'フルオープン','クローズド')}
11b.相手への開示要求: ${interp(s['11b'],'全部知りたい','知らなくていい（尊重）')}
　→ 11aと11bの関係: 自分の開示=${interp(s['11a'],'多い','少ない')}／相手への要求=${interp(s['11b'],'高い','低い')}
12.愛情表現: ${interp(s['12'],'言葉・言語派','行為・スキンシップ派')}
13.依存許容度: ${interp(s['13'],'頼られたい','自立を望む')}


TOP3と理由：
1位: ${t1} — ${r1}
2位: ${t2} — ${r2}
3位: ${t3} — ${r3}

MEMO: ${memo}

以下のJSON形式で返してください。返答はJSONのみ：
{"typeName":"...","theoryBasis":"...","catchcopy":"...","description":"...","contradiction":"...","strength":"...","experiment":"...","keywords":["kw1","kw2","kw3","kw4"],"phase2hint":"...","hypotheses":[{"direction":"方向性（10字以内）","desc":"この方向で実験する意味（1文）","actions":["アクション1","アクション2","アクション3"]},{"direction":"...","desc":"...","actions":["...","...","..."]},{"direction":"...","desc":"...","actions":["...","...","..."]}]}`;
}

async function sendToGemini() {
  const apiKey = document.getElementById('apiKey').value.trim();
  if (!apiKey) { showError('APIキーを入力してください'); return; }

  const model = document.getElementById('modelSelect').value;
  const prompt = buildData();
  const loading = document.getElementById('loadingMsg');
  const errEl = document.getElementById('errorMsg');
  const btn = document.querySelector('.send-btn');

  loading.style.display = 'block';
  errEl.style.display = 'none';
  btn.disabled = true;
  btn.style.opacity = '0.6';

  try {
    const res = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${apiKey}`,
      {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          contents: [{parts: [{text: prompt}]}],
          generationConfig: {temperature: 0.9, maxOutputTokens: 1500}
        })
      }
    );

    if (!res.ok) {
      const err = await res.json().catch(()=>({}));
      throw new Error(err?.error?.message || `HTTP ${res.status}`);
    }

    const data = await res.json();
    const text = data?.candidates?.[0]?.content?.parts?.[0]?.text || '';
    if (!text) throw new Error('レスポンスが空でした');

    showResult(text);
  } catch(e) {
    showError('エラー: ' + e.message);
  } finally {
    loading.style.display = 'none';
    btn.disabled = false;
    btn.style.opacity = '1';
  }
}

function showError(msg) {
  const el = document.getElementById('errorMsg');
  el.textContent = msg;
  el.style.display = 'block';
}

window.selectHyp = function(i) {
  document.querySelectorAll('.hyp-card').forEach((c,j)=>{
    c.classList.toggle('selected', j===i);
  });
  document.querySelectorAll('.actions-wrap').forEach((a,j)=>{
    a.classList.toggle('show', j===i);
  });
};

window.showResult = function(jsonStr) {
  try {
    const m = jsonStr.match(/\{[\s\S]*\}/);
    const r = JSON.parse(m ? m[0] : jsonStr);
    document.getElementById('rName').textContent = r.typeName||'';
    document.getElementById('rTheory').textContent = '📐 '+(r.theoryBasis||'');
    document.getElementById('rBody').innerHTML =
      (r.catchcopy?'<div class="catchcopy">'+r.catchcopy+'</div>':'')+
      '<p class="r-desc">'+(r.description||'')+'</p>'+
      (r.contradiction?'<div class="contradiction"><span class="cl">データが示す矛盾・盲点</span>'+r.contradiction+'</div>':'')+
      '<p class="r-desc"><b>強み：</b>'+(r.strength||'')+'</p>'+
      '<p class="r-desc"><b>今日から試せる実験：</b>'+(r.experiment||'')+'</p>';
    const kw = document.getElementById('rKw');
    kw.innerHTML='';
    (r.keywords||[]).forEach(k=>{const t=document.createElement('span');t.className='kw-tag';t.textContent=k;kw.appendChild(t);});
    document.getElementById('rPh2').textContent = r.phase2hint||'';

    // 仮説3択UI
    const hypEl = document.getElementById('rHyp');
    if (r.hypotheses && r.hypotheses.length) {
      let html = '<div class="hyp-section"><div class="hyp-section-label">PHASE 2 — 仮説の方向性を選ぶ</div><div class="hyp-cards">';
      r.hypotheses.forEach((h,i)=>{
        html += `<div>
          <div class="hyp-card" onclick="selectHyp(${i})">
            <div class="hyp-dir">${h.direction||''}</div>
            <div class="hyp-desc">${h.desc||''}</div>
            <span class="hyp-arrow">▶</span>
          </div>
          <div class="actions-wrap" id="act${i}">
            <div class="actions-label">具体アクション</div>
            ${(h.actions||[]).map((a,j)=>`<div class="action-item"><span class="action-num">${j+1}</span>${a}</div>`).join('')}
          </div>
        </div>`;
      });
      html += '</div></div>';
      hypEl.innerHTML = html;
    } else {
      hypEl.innerHTML = '';
    }

    document.getElementById('resultArea').style.display='block';
    document.getElementById('resultArea').scrollIntoView({behavior:'smooth',block:'start'});
  } catch(e) { showError('結果の表示に失敗しました: ' + e.message); console.error('showResult error:', e); }
};
</script>
